{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["request"],
  "properties": {
    "request": {
      "type": "string",
      "enum": ["launch", "attach"],
      "description": "Launch a new process or attach to an existing one"
    },
    "program": {
      "type": "string",
      "description": "Absolute path to the executable binary"
    },
    "cwd": {
      "type": "string",
      "description": "Working directory for the debuggee",
      "default": "${ZED_WORKTREE_ROOT}"
    },
    "args": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Command-line arguments",
      "default": []
    },
    "env": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Environment variables in KEY=VALUE format (e.g. [\"FOO=1\", \"BAR=hello\"])",
      "default": []
    },
    "pid": {
      "type": "integer",
      "description": "Process ID to attach to (attach mode only)"
    },
    "stopOnEntry": {
      "type": "boolean",
      "description": "Break at the entry point",
      "default": false
    },
    "waitFor": {
      "type": "boolean",
      "description": "Wait for process to launch before attaching (attach mode only)",
      "default": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "request": { "const": "launch" } }, "required": ["request"] },
      "then": { "required": ["program"] }
    },
    {
      "if": { "properties": { "request": { "const": "attach" } }, "required": ["request"] },
      "then": {
        "anyOf": [
          { "required": ["pid"] },
          { "required": ["program"] }
        ],
        "allOf": [
          {
            "if": { "required": ["pid"] },
            "then": { "not": { "properties": { "waitFor": { "const": true } } } }
          }
        ]
      }
    }
  ]
}
