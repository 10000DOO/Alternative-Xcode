{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["request"],
  "properties": {
    "request": {
      "type": "string",
      "enum": ["launch", "attach"],
      "description": "Launch a new process or attach to an existing one"
    },
    "program": {
      "type": "string",
      "description": "Absolute path to the executable binary"
    },
    "cwd": {
      "type": "string",
      "description": "Working directory for the debuggee",
      "default": "${ZED_WORKTREE_ROOT}"
    },
    "args": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Command-line arguments",
      "default": []
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Environment variables",
      "default": {}
    },
    "processId": {
      "type": "integer",
      "description": "Process ID to attach to (attach mode only)"
    },
    "stopOnEntry": {
      "type": "boolean",
      "description": "Break at the entry point",
      "default": false
    }
  },
  "if": { "properties": { "request": { "const": "launch" } } },
  "then": { "required": ["program"] }
}
